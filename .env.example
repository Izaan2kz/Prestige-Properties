# ─── Prestige Properties — Environment Variables ──────────────────────────────
#
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git — it is listed in .gitignore.
#
# Where to find these values:
#   Supabase Dashboard → Your Project → Project Settings → API
#
# ─────────────────────────────────────────────────────────────────────────────

# ── PUBLIC (safe to expose to the browser) ───────────────────────────────────

# Your Supabase project URL
# Example: https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Supabase anonymous/public key
# This key is intentionally public — it is restricted by Row Level Security (RLS)
# policies in your Supabase project to allow only SELECT on property tables.
# Found under: Project Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── SECRET (server-side only — NEVER prefix with NEXT_PUBLIC_) ───────────────

# Supabase service role key — bypasses ALL RLS policies
# Used ONLY in the server-side API route (app/api/contact/route.ts) to insert
# enquiries. This key must NEVER be exposed to the browser.
# Found under: Project Settings → API → Project API keys → service_role secret
# Rotate this key immediately if it is ever accidentally committed or exposed.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
